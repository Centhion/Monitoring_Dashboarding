  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Enterprise NOC",
      "tooltip": "",
      "type": "link",
      "url": "/d/enterprise-noc?var-environment=$environment"
    },
    {
      "asDropdown": false,
      "icon": "external link",
