    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "State of the DHCPServer Windows service. The service must be running for DHCP lease operations to function.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-text"
            },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "Running"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "Stopped"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "hostname"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "name"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Value"
          }
        ]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "windows_service_state{hostname=~\"$hostname\", name=\"DHCPServer\", state=\"running\", environment=~\"$environment\", datacenter=~\"$datacenter\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "DHCP Service Status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "datacenter": false,
              "environment": false,
              "instance": true,
              "job": true,
              "state": true
            },
            "indexByName": {
              "hostname": 0,
              "name": 1,
              "datacenter": 2,
              "environment": 3,
              "Value": 4
            },
            "renameByName": {
              "Value": "Status",
              "datacenter": "Datacenter",
              "environment": "Environment",
              "hostname": "Hostname",
              "name": "Service"
            }
          }
        }
      ],
      "type": "table"
    }
