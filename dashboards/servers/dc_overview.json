      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(windows_ad_ldap_client_sessions{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "Client Sessions",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Replication Objects Remaining",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of objects remaining for inbound replication sync. Zero indicates replication is fully converged. Any value above zero warrants investigation.",
      "id": 4,
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(windows_ad_replication_inbound_sync_objects_remaining{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "Objects Remaining",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LDAP Operations",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "LDAP search and bind operation rates over time, broken down by hostname. Useful for identifying load patterns and potential authentication storms.",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_ldap_searches_per_sec{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Searches",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_ldap_binds_per_sec{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Binds",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Replication Activity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "AD replication inbound and outbound object counts, sync requests, and replication byte rates over time. Spikes may indicate topology changes, schema updates, or forced replication events.",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*Inbound.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Outbound.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Bytes.*" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "Bps" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_replication_objects_inbound{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Inbound Objects",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_replication_objects_outbound{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Outbound Objects",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_dra_inbound_sync_requests_per_sec{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Inbound Sync Req",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (ad_ds_dra_outbound_sync_requests_per_sec{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "legendFormat": "{{ hostname }} Outbound Sync Req",
          "range": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (rate(windows_ad_replication_data_intrasite_bytes_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"}[5m]))",
          "legendFormat": "{{ hostname }} Intrasite Bytes",
          "range": true,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (hostname) (rate(windows_ad_replication_data_intersite_bytes_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"}[5m]))",
          "legendFormat": "{{ hostname }} Intersite Bytes",
          "range": true,
          "refId": "F"
        }
      ]
    },
    {
      "type": "row",
      "title": "Replication Health",
