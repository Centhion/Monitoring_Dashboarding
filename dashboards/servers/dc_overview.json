    {
      "type": "stat",
      "title": "LDAP Client Sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of currently connected LDAP client sessions across selected domain controllers.",
      "id": 3,
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
