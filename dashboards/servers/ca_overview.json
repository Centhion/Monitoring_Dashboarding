      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Template",
      "description": "Rate of certificate requests per second by template over time. Useful for identifying enrollment storms or unusual request patterns for specific templates.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 301,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cert_template) (rate(windows_adcs_requests_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"}[5m]))",
          "legendFormat": "{{cert_template}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
