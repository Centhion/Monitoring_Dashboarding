    {
      "type": "row",
      "title": "Per-Template Breakdown",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 200,
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Certificate Requests by Template",
      "description": "Per-template breakdown of certificate request totals, issuance counts, failures, pending requests, and average processing time. Failed column is color-coded: green for zero failures, red for any failures.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 201,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cert_template) (windows_adcs_requests_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Requests"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cert_template) (windows_adcs_issued_requests_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Issued"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cert_template) (windows_adcs_failed_requests_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Failed"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cert_template) (windows_adcs_pending_requests_total{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Pending"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "avg by (cert_template) (windows_adcs_request_processing_time_seconds{environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "ProcessingTime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Failed Total"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Processing Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Certificate Template"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 250
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Requests Total"
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true
            },
            "indexByName": {
              "cert_template": 0,
              "Value #Requests": 1,
              "Value #Issued": 2,
              "Value #Failed": 3,
              "Value #Pending": 4,
              "Value #ProcessingTime": 5
            },
            "renameByName": {
              "cert_template": "Certificate Template",
              "Value #Requests": "Requests Total",
              "Value #Issued": "Issued Total",
              "Value #Failed": "Failed Total",
              "Value #Pending": "Pending",
              "Value #ProcessingTime": "Avg Processing Time"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Issuance Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
