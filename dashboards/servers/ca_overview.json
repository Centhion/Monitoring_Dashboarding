  "description": "Active Directory Certificate Services (AD CS) monitoring dashboard. Displays certificate request totals, issuance counts, failure rates, per-template breakdowns, issuance trends, and CertSvc service health for all monitored Windows CA servers. Metrics sourced from Grafana Alloy via prometheus.exporter.windows adcs collector.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Enterprise NOC",
      "tooltip": "",
      "type": "link",
      "url": "/d/enterprise-noc?var-environment=$environment"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Site Overview",
      "tooltip": "",
      "type": "link",
      "url": "/d/site-overview?var-environment=$environment&var-datacenter=$datacenter"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Windows Servers",
      "tooltip": "",
      "type": "link",
      "url": "/d/windows-overview?var-environment=$environment&var-datacenter=$datacenter"
    },
    {
