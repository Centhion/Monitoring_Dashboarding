    {
      "id": 8,
      "type": "table",
      "title": "Top 10 CPU",
      "description": "Servers with highest average CPU utilization over the last 24 hours",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 10\n  me.Path AS \"Server\",\n  AVG(ph.AverageValue) AS \"Avg CPU %\",\n  MAX(ph.MaxValue) AS \"Peak CPU %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pri.ObjectName = 'Processor' AND pri.CounterName = '% Processor Time' AND pri.InstanceName = '_Total'\nAND ph.DateTime >= DATEADD(hour, -24, GETUTCDATE())\nGROUP BY me.Path\nORDER BY AVG(ph.AverageValue) DESC",
          "editorMode": "code"
        }
      ],
