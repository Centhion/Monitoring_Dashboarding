    {
      "id": 12,
      "type": "timeseries",
      "title": "Fleet CPU Trend",
      "description": "Fleet-wide average CPU utilization over time",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  ph.DateTime AS time,\n  AVG(ph.AverageValue) AS \"Fleet Avg CPU %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nWHERE pri.ObjectName = 'Processor' AND pri.CounterName = '% Processor Time' AND pri.InstanceName = '_Total'\nAND $__timeFilter(ph.DateTime)\nGROUP BY ph.DateTime\nORDER BY ph.DateTime",
          "editorMode": "code"
        }
      ],
