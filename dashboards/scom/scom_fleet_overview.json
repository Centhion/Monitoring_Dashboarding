    {
      "id": 10,
      "type": "table",
      "title": "Top 10 Lowest Disk",
      "description": "Disk volumes with the lowest free space percentage over the last 24 hours",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 10\n  me.Path AS \"Server\",\n  pri.InstanceName AS \"Drive\",\n  MIN(ph.AverageValue) AS \"Free %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pri.ObjectName = 'LogicalDisk' AND pri.CounterName = '% Free Space'\nAND pri.InstanceName NOT IN ('_Total', 'HarddiskVolume1')\nAND ph.DateTime >= DATEADD(hour, -24, GETUTCDATE())\nGROUP BY me.Path, pri.InstanceName\nORDER BY MIN(ph.AverageValue) ASC",
          "editorMode": "code"
        }
