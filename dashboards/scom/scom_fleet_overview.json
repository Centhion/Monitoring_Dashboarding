            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Critical Alerts\"\nFROM Alert.vAlert a\nWHERE a.ResolutionState <> 255 AND a.Severity = 2",
