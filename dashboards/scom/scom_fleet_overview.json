    {
      "id": 3,
      "type": "stat",
      "title": "Total Servers",
      "description": "Count of distinct Windows Computer managed entities",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT me.Path) AS \"Servers\"\nFROM vManagedEntity me\nINNER JOIN vManagedEntityType met ON me.ManagedEntityTypeRowId = met.ManagedEntityTypeRowId\nWHERE met.ManagedEntityTypeSystemName LIKE '%Computer%'",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
