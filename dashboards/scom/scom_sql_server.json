    {
      "id": 3,
      "type": "stat",
      "title": "Buffer Cache Hit Ratio",
      "description": "Percentage of pages found in the buffer cache without reading from disk. Values above 95% indicate healthy cache performance.",
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT TOP 1 ph.AverageValue AS \"Cache Hit %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pri.ObjectName = 'SQLServer:Buffer Manager' AND pri.CounterName = 'Buffer cache hit ratio'\nAND me.Path = '${server:raw}'\nAND $__timeFilter(ph.DateTime)\nORDER BY ph.DateTime DESC",
          "refId": "A"
        }
      ]
    },
