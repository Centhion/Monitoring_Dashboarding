          "format": "time_series",
          "rawSql": "SELECT ph.DateTime AS time, AVG(ph.AverageValue) AS \"Avg Memory %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pr.ObjectName = 'Memory' AND pr.CounterName = 'PercentMemoryUsed'\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nAND ('${role:raw}' = 'All' OR me.DisplayName LIKE 'VM-%-${role:raw}%')\nAND $__timeFilter(ph.DateTime)\nGROUP BY ph.DateTime ORDER BY ph.DateTime",
          "editorMode": "code"
        }
      ],
