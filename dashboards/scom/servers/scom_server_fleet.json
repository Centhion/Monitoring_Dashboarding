    {
      "id": 7,
      "type": "table",
      "title": "All Servers",
      "description": "Complete server inventory with health state, maintenance mode, resource utilization, and active alert counts. Click a server name to drill into detailed view.",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT\n  me.DisplayName AS \"Server\",\n  SUBSTRING(me.DisplayName, 4, CHARINDEX('-', me.DisplayName, 4) - 4) AS \"Site\",\n  CASE sh.NewHealthState WHEN 1 THEN 'Healthy' WHEN 2 THEN 'Warning' WHEN 3 THEN 'Critical' ELSE 'Unknown' END AS \"Health\",\n  CASE sh.InMaintenanceMode WHEN 1 THEN 'Yes' ELSE 'No' END AS \"Maint\",\n  cpu.AverageValue AS \"CPU %\",\n  mem.AverageValue AS \"Memory %\",\n  disk.AverageValue AS \"Disk Free %\",\n  alerts.cnt AS \"Alerts\"\nFROM vManagedEntity me\nLEFT JOIN (\n  SELECT ManagedEntityRowId, NewHealthState, InMaintenanceMode\n  FROM State.vStateHourly WHERE DateTime = (SELECT MAX(DateTime) FROM State.vStateHourly)\n) sh ON me.ManagedEntityRowId = sh.ManagedEntityRowId\nLEFT JOIN (\n  SELECT ph.ManagedEntityRowId, AVG(ph.AverageValue) AS AverageValue\n  FROM Perf.vPerfHourly ph\n  INNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\n  INNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\n  WHERE pr.ObjectName = 'Processor Information' AND pr.CounterName = '% Processor Time'\n  AND $__timeFilter(ph.DateTime)\n  GROUP BY ph.ManagedEntityRowId\n) cpu ON me.ManagedEntityRowId = cpu.ManagedEntityRowId\nLEFT JOIN (\n  SELECT ph.ManagedEntityRowId, AVG(ph.AverageValue) AS AverageValue\n  FROM Perf.vPerfHourly ph\n  INNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\n  INNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\n  WHERE pr.ObjectName = 'Memory' AND pr.CounterName = 'PercentMemoryUsed'\n  AND $__timeFilter(ph.DateTime)\n  GROUP BY ph.ManagedEntityRowId\n) mem ON me.ManagedEntityRowId = mem.ManagedEntityRowId\nLEFT JOIN (\n  SELECT ph.ManagedEntityRowId, AVG(ph.AverageValue) AS AverageValue\n  FROM Perf.vPerfHourly ph\n  INNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\n  INNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\n  WHERE pr.ObjectName = 'LogicalDisk' AND pr.CounterName = '% Free Space' AND pri.InstanceName = 'C:'\n  AND $__timeFilter(ph.DateTime)\n  GROUP BY ph.ManagedEntityRowId\n) disk ON me.ManagedEntityRowId = disk.ManagedEntityRowId\nLEFT JOIN (\n  SELECT a.ManagedEntityRowId, COUNT(*) AS cnt\n  FROM Alert.vAlert a WHERE a.ResolutionState <> 255\n  GROUP BY a.ManagedEntityRowId\n) alerts ON me.ManagedEntityRowId = alerts.ManagedEntityRowId\nWHERE me.ManagedEntityTypeRowId = 1\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nAND ('${role:raw}' = 'All' OR me.DisplayName LIKE 'VM-%-${role:raw}%')\nORDER BY sh.NewHealthState DESC, me.DisplayName",
          "editorMode": "code"
        }
      ],
