    {
      "id": 9,
      "type": "timeseries",
      "title": "Fleet CPU Trend",
      "description": "Average CPU utilization across filtered servers over time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
