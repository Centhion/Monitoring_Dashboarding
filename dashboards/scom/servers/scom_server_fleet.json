          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT me.DisplayName) AS \"Healthy\"\nFROM State.vStateHourly sh\nINNER JOIN vManagedEntity me ON sh.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE me.ManagedEntityTypeRowId = 1\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nAND ('${role:raw}' = 'All' OR me.DisplayName LIKE 'VM-%-${role:raw}%')\nAND sh.NewHealthState = 1\nAND sh.DateTime = (SELECT MAX(DateTime) FROM State.vStateHourly)",
