  "templating": {
    "list": [
      {
        "name": "site",
        "type": "query",
        "datasource": {
          "type": "mssql",
          "uid": "scom-dw"
        },
        "query": "SELECT DISTINCT LEFT(STUFF(me.DisplayName, 1, 3, ''), CHARINDEX('-', STUFF(me.DisplayName, 1, 3, '')) - 1) AS __text, LEFT(STUFF(me.DisplayName, 1, 3, ''), CHARINDEX('-', STUFF(me.DisplayName, 1, 3, '')) - 1) AS __value FROM vManagedEntity me WHERE me.ManagedEntityTypeRowId = 1 AND me.DisplayName LIKE 'VM-%' ORDER BY 1",
        "label": "Site",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "%",
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "server",
        "type": "query",
        "datasource": {
          "type": "mssql",
          "uid": "scom-dw"
        },
        "query": "SELECT DISTINCT me.DisplayName AS __text, me.DisplayName AS __value FROM vManagedEntity me WHERE me.ManagedEntityTypeRowId = 1 AND me.DisplayName LIKE 'VM-${site:raw}-IIS%' ORDER BY me.DisplayName",
        "label": "Server",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
