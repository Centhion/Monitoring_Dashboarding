      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": true,
          "fields": "/^Count$/"
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "rawSql": "SELECT\n  CASE a.Severity WHEN 2 THEN 'Critical' WHEN 1 THEN 'Warning' WHEN 0 THEN 'Info' END AS \"Severity\",\n  COUNT(*) AS \"Count\"\nFROM Alert.vAlert a\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE a.ResolutionState <> 255\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nGROUP BY a.Severity\nORDER BY a.Severity DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
