  "templating": {
    "list": [
      {
        "name": "site",
        "type": "query",
        "datasource": {
          "type": "mssql",
          "uid": "scom-dw"
        },
        "query": "SELECT DISTINCT LEFT(STUFF(me.DisplayName, 1, 3, ''), CHARINDEX('-', STUFF(me.DisplayName, 1, 3, '')) - 1) AS __text, LEFT(STUFF(me.DisplayName, 1, 3, ''), CHARINDEX('-', STUFF(me.DisplayName, 1, 3, '')) - 1) AS __value FROM vManagedEntity me WHERE me.ManagedEntityTypeRowId = 1 AND me.DisplayName LIKE 'VM-%' ORDER BY 1",
        "label": "Site",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "%",
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "server",
        "type": "query",
        "datasource": {
          "type": "mssql",
          "uid": "scom-dw"
        },
        "query": "SELECT DISTINCT me.DisplayName AS __text, me.DisplayName AS __value FROM vManagedEntity me WHERE me.ManagedEntityTypeRowId = 1 AND me.DisplayName LIKE 'VM-%' AND ('${site:raw}' = '%' OR me.DisplayName LIKE 'VM-${site:raw}-%') ORDER BY me.DisplayName",
        "label": "Server",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "%",
        "sort": 1
      },
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "All"
        },
        "description": "Filter alerts by severity level",
        "hide": 0,
        "includeAll": false,
        "label": "Severity",
        "multi": false,
        "name": "severity",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "All"
          },
          {
            "selected": false,
            "text": "Critical",
            "value": "Critical"
          },
          {
            "selected": false,
            "text": "Warning",
            "value": "Warning"
          },
          {
            "selected": false,
            "text": "Informational",
            "value": "Informational"
          }
        ],
        "query": "All,Critical,Warning,Informational",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
