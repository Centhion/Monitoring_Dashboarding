      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "rawSql": "SELECT COUNT(*) AS \"Last 24h\"\nFROM Alert.vAlert a\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE a.RaisedDateTime >= DATEADD(hour, -24, GETUTCDATE())\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'",
          "format": "table"
        }
      ]
    },
