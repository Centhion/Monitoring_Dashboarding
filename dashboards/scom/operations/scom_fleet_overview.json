          "format": "table",
          "rawSql": "SELECT TOP 10\n  me.DisplayName AS \"Server\",\n  pri.InstanceName AS \"Drive\",\n  MIN(ph.AverageValue) AS \"Free %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pr.ObjectName = 'LogicalDisk' AND pr.CounterName = '% Free Space'\nAND pri.InstanceName NOT IN ('_Total', 'HarddiskVolume1')\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nAND $__timeFilter(ph.DateTime)\nGROUP BY me.DisplayName, pri.InstanceName\nORDER BY MIN(ph.AverageValue) ASC",
          "editorMode": "code"
        }
