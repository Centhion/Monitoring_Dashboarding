    {
      "id": 6,
      "type": "stat",
      "title": "Active Critical Alerts",
      "description": "Count of unresolved severity-2 (critical) alerts",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Critical Alerts\"\nFROM Alert.vAlert a\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE a.ResolutionState <> 255 AND a.Severity = 2\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'",
          "editorMode": "code"
        }
      ],
