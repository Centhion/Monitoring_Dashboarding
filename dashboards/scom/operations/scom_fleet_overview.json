    {
      "id": 21,
      "type": "table",
      "title": "Per-Site Summary",
      "description": "Server count, average CPU, average memory, and active alerts per site",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT\n  SUBSTRING(me.DisplayName, 4, CHARINDEX('-', me.DisplayName, 4) - 4) AS \"Site\",\n  COUNT(DISTINCT me.ManagedEntityRowId) AS \"Servers\",\n  AVG(CASE WHEN pr.CounterName = '% Processor Time' THEN ph.AverageValue END) AS \"Avg CPU %\",\n  AVG(CASE WHEN pr.CounterName = 'PercentMemoryUsed' THEN ph.AverageValue END) AS \"Avg Memory %\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pr.CounterName IN ('% Processor Time', 'PercentMemoryUsed')\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'\nAND $__timeFilter(ph.DateTime)\nGROUP BY SUBSTRING(me.DisplayName, 4, CHARINDEX('-', me.DisplayName, 4) - 4)\nORDER BY 1",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
