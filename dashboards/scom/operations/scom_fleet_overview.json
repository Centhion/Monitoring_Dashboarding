    {
      "id": 8,
      "type": "table",
      "title": "Top 10 CPU",
      "description": "Servers with highest average CPU utilization over the selected time range",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "mssql",
