    {
      "id": 10,
      "type": "bargauge",
      "title": "Top Alerted Servers",
      "description": "Servers generating the most alerts, with critical and warning breakdown",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 10\n  me.DisplayName AS \"Server\",\n  COUNT(*) AS \"Alerts\",\n  SUM(CASE WHEN a.Severity = 2 THEN 1 ELSE 0 END) AS \"Critical\",\n  SUM(CASE WHEN a.Severity = 1 THEN 1 ELSE 0 END) AS \"Warning\"\nFROM Alert.vAlert a\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(a.RaisedDateTime)\nGROUP BY me.DisplayName\nORDER BY COUNT(*) DESC",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^Alerts$/",
          "values": true
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "valueMode": "text"
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Most Common Alerts",
      "description": "Alert names generating the highest volume, with server spread and max severity",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 8,
        "y": 23
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
