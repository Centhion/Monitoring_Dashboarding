    {
      "id": 17,
      "type": "timeseries",
      "title": "Fleet CPU Trend (Daily)",
      "description": "Daily average CPU utilization across the fleet from SCOM Data Warehouse daily rollups (Perf.vPerfDaily). Useful for spotting long-term capacity trends.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  ph.DateTime AS time,\n  AVG(ph.AverageValue) AS \"Fleet Avg CPU %\"\nFROM Perf.vPerfDaily ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pr.ObjectName = 'Processor Information' AND pr.CounterName = '% Processor Time'\nAND me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(ph.DateTime)\nGROUP BY ph.DateTime\nORDER BY ph.DateTime",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
