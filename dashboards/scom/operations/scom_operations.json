              "options": "Info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showValues": "current",
          "calcs": [
            "sum",
            "mean"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Event Error Trend",
      "description": "Daily event error and warning counts from Windows Event Log",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  CAST(e.DateTime AS DATE) AS time,\n  el.EventLevelName AS metric,\n  COUNT(*) AS value\nFROM Event.vEvent e\nINNER JOIN dbo.vEventLevel el ON e.EventLevelId = el.EventLevelId\nINNER JOIN dbo.vEventLoggingComputer elc ON e.LoggingComputerRowId = elc.LoggingComputerRowId\nWHERE elc.LoggingComputerName LIKE 'VM-${site:raw}-%'\nAND el.EventLevelId <= 2\nAND $__timeFilter(e.DateTime)\nGROUP BY CAST(e.DateTime AS DATE), el.EventLevelName\nORDER BY CAST(e.DateTime AS DATE)",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
