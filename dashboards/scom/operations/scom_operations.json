    {
      "id": 15,
      "type": "table",
      "title": "Slowest Resolvers",
      "description": "Users with the longest average alert resolution times",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 10\n  ars.StateSetByUserId AS \"Resolver\",\n  COUNT(*) AS \"Alerts Resolved\",\n  AVG(ars.TimeFromRaisedSeconds) / 60 AS \"Avg Resolution (min)\",\n  MAX(ars.TimeFromRaisedSeconds) / 60 AS \"Slowest (min)\"\nFROM Alert.vAlertResolutionState ars\nINNER JOIN Alert.vAlert a ON ars.AlertGuid = a.AlertGuid\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE ars.ResolutionState = 255\nAND me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(ars.StateSetDateTime)\nGROUP BY ars.StateSetByUserId\nORDER BY AVG(ars.TimeFromRaisedSeconds) DESC",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
