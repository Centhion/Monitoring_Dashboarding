            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 20\n  me.DisplayName AS \"Server\",\n  mm.StartDateTime AS \"Start\",\n  mm.EndDateTime AS \"End\",\n  mmh.Comment AS \"Reason\",\n  mmh.UserId AS \"Set By\",\n  CASE mm.PlannedMaintenanceInd WHEN 1 THEN 'Planned' ELSE 'Unplanned' END AS \"Type\"\nFROM dbo.vMaintenanceMode mm\nINNER JOIN vManagedEntity me ON mm.ManagedEntityRowId = me.ManagedEntityRowId\nLEFT JOIN dbo.vMaintenanceModeHistory mmh ON mm.MaintenanceModeRowId = mmh.MaintenanceModeRowId\nWHERE me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(mm.StartDateTime)\nORDER BY mm.StartDateTime DESC",
          "editorMode": "code"
        }
      ],
