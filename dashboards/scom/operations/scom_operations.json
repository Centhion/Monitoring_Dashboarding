              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^Count$/",
          "values": true
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "valueMode": "text"
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Top Event Error Sources",
      "description": "Event log publishers generating the most errors, with server spread",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 23
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT TOP 10\n  ep.EventPublisherName AS \"Source\",\n  COUNT(*) AS \"Errors\",\n  COUNT(DISTINCT elc.LoggingComputerName) AS \"Servers\"\nFROM Event.vEvent e\nINNER JOIN dbo.vEventPublisher ep ON e.EventPublisherRowId = ep.EventPublisherRowId\nINNER JOIN dbo.vEventLevel el ON e.EventLevelId = el.EventLevelId\nINNER JOIN dbo.vEventLoggingComputer elc ON e.LoggingComputerRowId = elc.LoggingComputerRowId\nWHERE el.EventLevelName = 'Error'\nAND elc.LoggingComputerName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(e.DateTime)\nGROUP BY ep.EventPublisherName\nORDER BY COUNT(*) DESC",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
