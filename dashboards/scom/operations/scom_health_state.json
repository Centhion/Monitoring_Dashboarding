      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT me.DisplayName) AS \"Healthy\"\nFROM State.vStateHourly sh\nINNER JOIN vManagedEntity me ON sh.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE me.ManagedEntityTypeRowId = 1\nAND sh.NewHealthState = 1\nAND sh.DateTime = (SELECT MAX(DateTime) FROM State.vStateHourly)\nAND me.DisplayName LIKE 'VM-' + '${site:raw}' + '-%'",
          "refId": "A"
        }
      ]
    },
