            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Server"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Server Overview",
                    "url": "/d/scom-server-detail?var-server=${__data.fields.Server:raw}",
                    "targetBlank": false
