{
  "id": null,
  "uid": "scom-incident",
  "title": "SCOM Incident Investigation",
  "description": "Primary troubleshooting dashboard for investigating a specific server issue. All critical data on one screen for one server.",
  "tags": [
    "scom",
    "troubleshooting",
    "incident"
  ],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 2,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "Fleet Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/scom-fleet-overview",
      "keepTime": true,
      "targetBlank": false
