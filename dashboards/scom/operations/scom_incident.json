      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT TOP 20\n  a.RaisedDateTime AS \"Raised\",\n  a.AlertName AS \"Alert\",\n  CASE a.Severity WHEN 2 THEN 'Critical' WHEN 1 THEN 'Warning' ELSE 'Info' END AS \"Severity\",\n  CASE a.ResolutionState WHEN 0 THEN 'Active' WHEN 255 THEN 'Closed' ELSE 'Other' END AS \"Status\",\n  ad.RepeatCount AS \"Repeats\",\n  a.AlertDescription AS \"Description\"\nFROM Alert.vAlert a\nLEFT JOIN Alert.vAlertDetail ad ON a.AlertGuid = ad.AlertGuid\nINNER JOIN vManagedEntity me ON a.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE ('${server:raw}' = '$__all' OR me.DisplayName = '${server:raw}')\nAND me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(a.RaisedDateTime)\nORDER BY a.RaisedDateTime DESC",
          "refId": "A"
        }
      ]
    },
