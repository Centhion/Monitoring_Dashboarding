      "title": "Correlated Events & Alerts",
      "type": "row"
    },
    {
      "id": 12,
      "type": "table",
      "title": "Recent Alerts",
      "description": "All alerts raised for this server in the selected time range, ordered by most recent.",
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Critical": {
                        "color": "red",
                        "index": 0,
                        "text": "Critical"
                      },
                      "Warning": {
                        "color": "yellow",
                        "index": 1,
                        "text": "Warning"
