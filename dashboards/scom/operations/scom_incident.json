          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT\n  m.MonitorDefaultName AS \"Monitor\",\n  CASE sh.NewHealthState WHEN 1 THEN 'Healthy' WHEN 2 THEN 'Warning' WHEN 3 THEN 'Critical' END AS \"State\",\n  sh.DateTime AS \"Last Changed\"\nFROM State.vStateHourly sh\nINNER JOIN vManagedEntityMonitor mem ON sh.ManagedEntityRowId = mem.ManagedEntityRowId AND sh.MonitorRowId = mem.MonitorRowId\nINNER JOIN dbo.vMonitor m ON mem.MonitorRowId = m.MonitorRowId\nINNER JOIN vManagedEntity me ON sh.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE me.DisplayName = '${server:raw}'\nAND sh.NewHealthState > 1\nAND sh.DateTime = (SELECT MAX(s2.DateTime) FROM State.vStateHourly s2 WHERE s2.ManagedEntityRowId = sh.ManagedEntityRowId AND s2.MonitorRowId = sh.MonitorRowId)\nORDER BY sh.NewHealthState DESC, m.MonitorDefaultName",
