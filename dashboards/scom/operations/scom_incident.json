          "rawSql": "SELECT\n  sh.DateTime AS time,\n  'Health' AS metric,\n  CASE sh.NewHealthState WHEN 1 THEN 'Healthy' WHEN 2 THEN 'Warning' WHEN 3 THEN 'Critical' ELSE 'Unknown' END AS value\nFROM State.vStateRaw sh\nINNER JOIN vManagedEntity me ON sh.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE ('${server:raw}' = '$__all' OR me.DisplayName = '${server:raw}')\nAND me.DisplayName LIKE 'VM-${site:raw}-%'\nAND $__timeFilter(sh.DateTime)\nORDER BY sh.DateTime",
