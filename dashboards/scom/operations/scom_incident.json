      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT TOP 50\n  e.DateTime AS \"Time\",\n  el.EventLevelName AS \"Level\",\n  ep.EventPublisherName AS \"Source\",\n  e.EventDisplayNumber AS \"Event ID\",\n  e.RawDescription AS \"Description\"\nFROM Event.vEvent e\nINNER JOIN dbo.vEventPublisher ep ON e.EventPublisherRowId = ep.EventPublisherRowId\nINNER JOIN dbo.vEventLevel el ON e.EventLevelId = el.EventLevelId\nINNER JOIN dbo.vEventLoggingComputer elc ON e.LoggingComputerRowId = elc.LoggingComputerRowId\nWHERE ('${server:raw}' = '$__all' OR elc.LoggingComputerName = '${server:raw}')\nAND elc.LoggingComputerName LIKE 'VM-${site:raw}-%'\nAND el.EventLevelId <= 2\nAND $__timeFilter(e.DateTime)\nORDER BY e.DateTime DESC",
          "refId": "A"
        }
