    {
      "id": 9,
      "type": "table",
      "title": "All Servers",
      "description": "Full server inventory with health state, maintenance mode, and resource utilization",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT\n  me.DisplayName AS \"Server\",\n  CASE sh.NewHealthState WHEN 1 THEN 'Healthy' WHEN 2 THEN 'Warning' WHEN 3 THEN 'Critical' ELSE 'Unknown' END AS \"Health\",\n  CASE sh.InMaintenanceMode WHEN 1 THEN 'Yes' ELSE 'No' END AS \"Maintenance\",\n  cpu.AverageValue AS \"CPU %\",\n  mem.AverageValue AS \"Memory %\"\nFROM vManagedEntity me\nLEFT JOIN (\n  SELECT ManagedEntityRowId, NewHealthState, InMaintenanceMode\n  FROM State.vStateHourly\n  WHERE DateTime = (SELECT MAX(DateTime) FROM State.vStateHourly)\n) sh ON me.ManagedEntityRowId = sh.ManagedEntityRowId\nLEFT JOIN (\n  SELECT ph.ManagedEntityRowId, AVG(ph.AverageValue) AS AverageValue\n  FROM Perf.vPerfHourly ph\n  INNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\n  INNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\n  WHERE pr.ObjectName = 'Processor Information' AND pr.CounterName = '% Processor Time'\n  AND $__timeFilter(ph.DateTime)\n  GROUP BY ph.ManagedEntityRowId\n) cpu ON me.ManagedEntityRowId = cpu.ManagedEntityRowId\nLEFT JOIN (\n  SELECT ph.ManagedEntityRowId, AVG(ph.AverageValue) AS AverageValue\n  FROM Perf.vPerfHourly ph\n  INNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\n  INNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\n  WHERE pr.ObjectName = 'Memory' AND pr.CounterName = 'PercentMemoryUsed'\n  AND $__timeFilter(ph.DateTime)\n  GROUP BY ph.ManagedEntityRowId\n) mem ON me.ManagedEntityRowId = mem.ManagedEntityRowId\nWHERE me.ManagedEntityTypeRowId = 1\nAND me.DisplayName LIKE 'VM-${site:raw}-%'\nORDER BY sh.NewHealthState DESC, me.DisplayName",
          "editorMode": "code"
        }
      ],
