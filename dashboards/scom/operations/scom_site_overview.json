    {
      "id": 2,
      "type": "stat",
      "title": "Total Servers",
      "description": "Count of distinct Windows Computer managed entities at this site",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT me.DisplayName) AS \"Servers\"\nFROM vManagedEntity me\nWHERE me.ManagedEntityTypeRowId = 1\nAND me.DisplayName LIKE 'VM-${site:raw}-%'",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
