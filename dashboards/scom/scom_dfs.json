    {
      "id": 3,
      "type": "stat",
      "title": "Staging Space In Use",
      "description": "Current DFS staging space consumption. High staging usage can stall replication if the staging quota is exceeded.",
      "datasource": {
        "type": "mssql",
        "uid": "scom-dw"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3000
              },
              {
                "color": "red",
                "value": 4500
              }
            ]
          },
          "unit": "deckbytes",
          "decimals": 0,
          "min": 100,
          "max": 5000
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT TOP 1 ph.AverageValue AS \"Staging Space In Use\"\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vPerformanceRule pr ON pri.RuleRowId = pr.RuleRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE pr.ObjectName = 'DFS Replicated Folders' AND pr.CounterName = 'Staging Space In Use'\nAND me.DisplayName = '${server:raw}'\nAND $__timeFilter(ph.DateTime)\nORDER BY ph.DateTime DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Conflict Space In Use",
