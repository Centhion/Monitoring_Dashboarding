      "targets": [
        {
          "datasource": {
            "type": "mssql",
            "uid": "scom-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT\n  ph.DateTime AS time,\n  pri.ObjectName + ' - ' + pri.CounterName AS metric,\n  ph.AverageValue AS value\nFROM Perf.vPerfHourly ph\nINNER JOIN vPerformanceRuleInstance pri ON ph.PerformanceRuleInstanceRowId = pri.PerformanceRuleInstanceRowId\nINNER JOIN vManagedEntity me ON ph.ManagedEntityRowId = me.ManagedEntityRowId\nWHERE (\n  (pri.ObjectName = 'Web Service' AND pri.CounterName = 'Total Method Requests/sec' AND pri.InstanceName = '_Total')\n  OR (pri.ObjectName = 'ASP.NET Applications' AND pri.CounterName = 'Requests/Sec' AND pri.InstanceName = '__Total__')\n)\nAND me.Path = '${server:raw}'\nAND $__timeFilter(ph.DateTime)\nORDER BY ph.DateTime",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "multi"
          }
        }
      ]
    },
