# =============================================================================
# SCOM-Only Deployment -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your production values.
#
# Usage:
#   cp .env.scom.example .env
#   # Edit .env with your values
#   docker compose -f docker-compose.scom.yml up -d
# =============================================================================

# SCOM Data Warehouse SQL Server connection
SCOM_DW_HOST=VM-DEN-SQL11
SCOM_DW_PORT=1433
SCOM_DW_DATABASE=OperationsManagerDW
SCOM_DW_USER=svc-omread
SCOM_DW_PASSWORD=CHANGE_ME

# Grafana admin credentials (change for production)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Grafana port (default 3000)
GRAFANA_PORT=3000
